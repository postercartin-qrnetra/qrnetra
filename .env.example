# Supabase (Project Settings → API)
# Public — safe to expose in the browser via NEXT_PUBLIC_*
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Used for absolute QR links in dashboard (e.g. https://your-domain.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Auth → URL configuration: add these Redirect URLs:
# - http://localhost:3000/auth/callback
# - https://YOUR_PRODUCTION_DOMAIN/auth/callback
# Enable Google provider in Authentication → Providers, then set Web client ID/secret.

# Server-only — never expose to the client or commit real values
# Used for admin scripts, webhooks, or bypassing RLS when strictly necessary
SUPABASE_SERVICE_ROLE_KEY=
